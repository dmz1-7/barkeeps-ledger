# ---- Barkeep's Ledger configuration ----
# Copy to .env and fill in. All values are optional except ANTHROPIC_API_KEY
# (needed to read invoice photos). Everything else can also be set in-app
# under "The Forge" (Settings).

# Claude API key — required for invoice photo reading.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Passcode gate. Leave blank to run open (fine on a trusted home network).
# Set it before exposing the app to the wider internet.
APP_PASSWORD=
# Secret used to sign the session token. Change it to any random string.
APP_SECRET=change-me-to-something-random

# Square — can also be entered in the Settings page instead of here.
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=

# Which Claude model reads invoices (opus = most accurate, haiku = cheapest).
LEDGER_AI_MODEL=claude-opus-4-8

# Where to listen.
HOST=0.0.0.0
PORT=8088
